Screen {
    layout: vertical;
}

ConfigPanel {
    height: auto;
    margin-bottom: 1;
}

#view-tabs {
    height: 1fr;
}

TimesheetTable {
    height: 1fr;
    min-height: 10;
}

CalendarView {
    height: 1fr;
    min-height: 10;
}

SummaryPanel {
    height: auto;
    margin-top: 1;
}

#log-panel {
    height: 10;
    min-height: 6;
    max-height: 20;
    margin-top: 1;
    border: solid $accent;
    display: block;
}

#log-panel.hidden {
    display: none;
}
